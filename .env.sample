PORT=5002

# Database Configuration
DB_HOST="job-finder-db"
DB_USER="job_finder_user"
DB_PASS="your_secure_password_123"
DATABASE_URL="postgresql://job_finder_user:your_secure_password_123@job-finder-db:5432/job_finder"

# JWT Token Secrets (generate strong random values for production)
ACCESS_TOKEN_SECRET=""
ACCESS_TOKEN_EXPIRES_IN="15m"
ACCESS_TOKEN_MAX_AGE_MS=900000        # 15 * 60 * 1000
REFRESH_TOKEN_SECRET=""
REFRESH_TOKEN_EXPIRES_IN="7d"
REFRESH_TOKEN_MAX_AGE_MS=604800000    # 7 * 24 * 60 * 60 * 1000

# Redis / Message Queue
REDIS_URL="redis://job-finder-redis:6379"
QUEUE_CONCURRENCY=5

NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"